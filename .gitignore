/node_modules
/.pnpm-store/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/tmp/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# screenshots / temp
.screenshot-*.png

# pipeline artifacts
.pipeline/

# lighthouse reports
.lighthouse/
.lighthouseci/
.lighthouse-mobile/

# tooling caches
.agents/
.workbuddy/

# generated reports (Trae Work / ad-hoc HTML)
blog-next-steps/
blog-progress-report/
project-diagnostic-report/
优化方案.html
项目深度分析与代码审查报告.html

# vitest HTML report
/html/

