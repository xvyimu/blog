/task_plan.md
/findings.md
/progress.md

# stryker mutation testing
/stryker-report/
.stryker-tmp/

# npm lockfile (project uses pnpm)
package-lock.json

# debug
/debug.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (template is committed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# logs
*.log

# dev output
.dev-out.log

# local tool (codebase-memory) - do not commit
.cbmignore
